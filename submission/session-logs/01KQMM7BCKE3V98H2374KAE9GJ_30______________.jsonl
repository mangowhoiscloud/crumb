{"session_id":"01KQMM7BCKE3V98H2374KAE9GJ","from":"planner-lead","kind":"step.design","parent_event_id":"01KQMMWAE6MCEA14RVJBJM432V","body":"Palette locked at researcher's 5-hue Tailwind-500 set on slate-900 bg; tile=56px circles with 12px glow on grab; motion = 80ms match-pop / 200ms miss-shake / 250ms tier-flash / 300ms game-over fade; HUD = 8vh timer-row, 72vh play-area, 10vh slot-row (5 slots @ 18vw), 10vh combo footer","data":{"palette":{"background":"#0f172a","foreground":"#f8fafc","tile_hues":["#ef4444","#f59e0b","#10b981","#3b82f6","#a855f7"],"miss_red":"#dc2626","success_green":"#22c55e","rationale":"Tailwind 500-tier on slate-900: ΔE≥60 between hues, WCAG-AA contrast against bg, deuteranopia-safe per researcher lesson 3"},"tile_design":{"shape":"circle","diameter_px":56,"drop_shadow":"0 4px 12px rgba(0,0,0,0.4)","grab_glow":"0 0 24px var(--tile-color)","label":"none (color-only — contrast carries semantics)"},"motion":{"fall_easing":"linear (px/s — driven by tuning.spawn_curve)","grab_response_ms":16,"match_pop_ms":80,"match_pop_curve":"scale 1.0 → 1.15 → 1.0","miss_shake_ms":200,"miss_shake_amplitude_px":8,"tier_flash_ms":250,"tier_flash_property":"top + bottom edge box-shadow pulse to current-tier hue","game_over_fade_ms":300},"hud_layout":{"orientation":"portrait","viewport_units":"vh/vw (responsive)","rows":[{"id":"timer_row","height":"8vh","content":"timer-left | score-center | miss-pips-right (3 pips, filled red on miss)"},{"id":"play_area","height":"72vh","content":"falling-circle-spawn-zone (top-edge → bottom-of-play-area)"},{"id":"slot_row","height":"10vh","content":"5 color slots, each 18vw wide, gap=2vw, centered horizontally; slots accept drop within 12px tolerance of slot edge"},{"id":"footer","height":"10vh","content":"combo display (e.g., 'x2.5!') fades in 80ms on combo, fades out 600ms after combo break"}],"safe_area_padding_vh":2},"accessibility":{"contrast_aa":true,"min_tap_target_px":70,"colorblind_mode":"default-on (palette is already C