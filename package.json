{
  "name": "crumb",
  "version": "1.0.0",
  "description": "Multi-agent execution harness for casual game prototyping. Pitch a game in one line, watch agents collaborate, intervene anytime.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "crumb": "dist/index.js"
  },
  "files": [
    "dist",
    "protocol/schemas/**/*.json",
    "agents/**/*.md",
    "skills/**/*.md",
    "skills/**/*.py",
    "skills/**/LICENSE.txt",
    ".crumb/presets/*.toml",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "README.ko.md",
    "!**/__pycache__",
    "!**/*.pyc",
    "!**/*.test.ts",
    "!**/*.test.js",
    "!**/*.test.d.ts",
    "!**/*.test.js.map",
    "!**/*.spec.ts",
    "!**/*.spec.js",
    "!**/*.tsbuildinfo"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "inline-studio-client": "npm run inline-client --workspace=@crumb/studio --if-present",
    "build": "tsc && npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present",
    "lint": "eslint . --ext .ts",
    "lint:knip": "knip --no-progress",
    "lint:deps": "depcruise src --config .dependency-cruiser.cjs",
    "lint:all": "npm run lint && npm run lint:knip && npm run lint:deps",
    "format:check": "prettier --check \"src/**/*.ts\" \"packages/*/src/**/*.ts\" \"protocol/schemas/**/*.json\" \"package.json\" \"tsconfig.json\"",
    "format": "prettier --write \"src/**/*.ts\" \"packages/*/src/**/*.ts\" \"protocol/schemas/**/*.json\" \"package.json\" \"tsconfig.json\"",
    "pretest": "npm run inline-studio-client",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "setup": "node scripts/setup.mjs",
    "update": "node scripts/update.mjs",
    "uninstall": "node scripts/uninstall.mjs",
    "reset": "node scripts/reset.mjs",
    "sandwich:update-hashes": "tsx scripts/update-sandwich-hashes.mjs",
    "postinstall": "node scripts/qa-postinstall.js"
  },
  "keywords": [
    "multi-agent",
    "orchestrator",
    "claude-code",
    "codex",
    "game-prototyping",
    "transcript",
    "observability"
  ],
  "author": "mango",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "blessed": "^0.1.81",
    "chokidar": "^3.6.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^8.57.0",
    "eslint-plugin-sonarjs": "^0.25.1",
    "knip": "^6.11.0",
    "playwright": "^1.59.1",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
