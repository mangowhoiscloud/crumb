# dependencies
node_modules/

# build output
dist/
*.tsbuildinfo

# studio client inliner artifact — regenerated on prebuild / pretypecheck
# from packages/studio/src/client/{studio.html, studio.css, studio.js}
packages/studio/src/studio-html.generated.ts

# runtime sessions (generated, never commit)
sessions/

# logs
*.log
npm-debug.log*

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# env
.env
.env.local
.env.*.local

# user config (project-level config.toml is committed; user override is not)
.crumb/config.local.toml

# v3.2 G4 — per-machine sandwich overrides. Base agents/<actor>.md is committed;
# agents/<actor>.local.md is a local-only addendum the dispatcher concatenates
# during assembly (sessions/<id>/agent-workspace/<actor>/sandwich.assembled.md).
agents/*.local.md

# Maintainer skills (mirrored from ~/workspace/mango-wiki/.skills/) ARE
# committed at .skills/ — they document the workflow used to build this
# repo (wiki ingest, gitflow, anti-deception checklist, deep-researcher,
# karpathy-patterns, codebase-audit, etc.). The runtime `skills/` bundle
# (no dot) is what actors load at spawn time; `.skills/` here is for
# evaluators + future contributors who want to see how the work happened.

# temp
tmp/
.tmp/
.claude/scheduled_tasks.lock
