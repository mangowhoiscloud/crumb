# dependencies
node_modules/

# build output
dist/
*.tsbuildinfo

# runtime sessions (generated, never commit)
sessions/

# logs
*.log
npm-debug.log*

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# env
.env
.env.local
.env.*.local

# user config (project-level config.toml is committed; user override is not)
.crumb/config.local.toml

# Maintainer-only operational skills (mirrored from ~/workspace/mango-wiki/.skills/).
# The committed skills/ bundle is what evaluators see; .skills/ is local working tooling.
.skills/

# temp
tmp/
.tmp/
.claude/scheduled_tasks.lock
