{
  "name": "@crumb/dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Live observability dashboard for Crumb sessions — file-tail SSE server + browser UI.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js"
