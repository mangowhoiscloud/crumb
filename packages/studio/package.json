{
  "name": "@crumb/studio",
  "version": "0.4.0",
  "private": true,
  "description": "Live observability studio for Crumb sessions — file-tail SSE server + browser UI.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js"
  },
  "bin": {
    "crumb-studio": "dist/cli.js"
  },
  "scripts": {
    "inline-client": "node scripts/inline-client.mjs",
    "prebuild": "node scripts/inline-client.mjs",
    "pretypecheck": "node scripts/inline-client.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "chokidar": "^3.6.0"
  }
}
