{
  "name": "@crumb/studio",
  "version": "0.4.0",
  "description": "Crumb Studio — local web console for spawning Crumb sessions, watching transcripts in real time, and intervening (approve / veto / pause / goto / swap / append). File-tail SSE server + browser UI; no cloud, no API key.",
  "license": "MIT",
  "author": "mango",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js"
  },
  "bin": {
    "crumb-studio": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts/inline-client.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "crumb",
    "studio",
    "console",
    "observability",
    "sse",
    "transcript",
    "multi-agent",
    "live",
    "file-tail"
  ],
  "homepage": "https://github.com/mangowhoiscloud/crumb#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mangowhoiscloud/crumb.git",
    "directory": "packages/studio"
  },
  "bugs": {
    "url": "https://github.com/mangowhoiscloud/crumb/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "inline-client": "node scripts/inline-client.mjs",
    "build:client-v2": "vite build",
    "prebuild": "node scripts/inline-client.mjs && npm run build:client-v2",
    "pretypecheck": "node scripts/inline-client.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client-v2.json --noEmit",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@iarna/toml": "^2.2.5",
    "@tanstack/react-query": "^5.100.8",
    "@xyflow/react": "^12.10.2",
    "chokidar": "^3.6.0",
    "dockview-react": "^6.0.0",
    "open-props": "^1.7.23",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "vite": "^6.0.7"
  },
  "peerDependencies": {
    "crumb": "^0.4.0"
  },
  "peerDependenciesMeta": {
    "crumb": {
      "optional": true
    }
  }
}
